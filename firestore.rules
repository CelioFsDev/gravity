rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserEmail() {
      return request.auth.token.email;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        currentUserEmail() == 'ti.vitoriana@gmail.com' || 
        currentUserEmail() == 'celiofs.dev@gmail.com' ||
        currentUserEmail() == 'celio@gmail.com' ||
        currentUserEmail() == 'celioferreira.dev@gmail.com'
      );
    }

    function userDocExists() {
      return isSignedIn()
        && currentUserEmail() != null
        && exists(/databases/$(database)/documents/users/$(currentUserEmail()));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(currentUserEmail())).data;
    }

    function isAdmin() {
      return isSuperAdmin();
    }

    function getTenantIds() {
      return exists(/databases/$(database)/documents/users/$(currentUserEmail()))
        ? get(/databases/$(database)/documents/users/$(currentUserEmail())).data.tenantIds
        : [];
    }

    function isSelf(userEmail) {
      return isSignedIn()
        && currentUserEmail() != null
        && currentUserEmail() == userEmail;
    }

    function isOwner(resourceData) {
      return isSignedIn() && resourceData.ownerUid == request.auth.uid;
    }

    // --- SaaS Rule: Ensure data belongs to current user's tenant ---
    function isFromTenant(resourceData) {
      return isSignedIn() && (resourceData.tenantId in getTenantIds() || isAdmin());
    }

    function isWritingForTenant() {
      return isSignedIn() && (request.resource.data.tenantId in getTenantIds() || isAdmin());
    }

    match /users/{userEmail} {
      allow read: if isSignedIn() && (isAdmin() || isSelf(userEmail));
      allow create: if isSignedIn() && (isAdmin() || isSelf(userEmail));
      allow update: if isSignedIn() && (isAdmin() || isSelf(userEmail));
      allow delete: if isAdmin();
    }

    match /tenants/{tenantId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (tenantId in getTenantIds() || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (tenantId in getTenantIds() || isAdmin());
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isWritingForTenant();
      allow update: if isFromTenant(resource.data) && isWritingForTenant();
      allow delete: if isFromTenant(resource.data);
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isWritingForTenant();
      allow update: if isFromTenant(resource.data) && isWritingForTenant();
      allow delete: if isFromTenant(resource.data);
    }

    match /catalogs/{catalogId} {
      allow read: if true; 
      allow create: if isWritingForTenant();
      allow update: if isFromTenant(resource.data) && isWritingForTenant();
      allow delete: if isFromTenant(resource.data);

      match /items/{itemId} {
        allow read: if true; // Items de catálogo público são abertos para visualizadores
        allow write: if isFromTenant(get(/databases/$(database)/documents/catalogs/$(catalogId)).data);
      }
    }
  }
}
