rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserEmail() {
      return request.auth.token.email;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        currentUserEmail() == 'ti.vitoriana@gmail.com' || 
        currentUserEmail() == 'celiofs.dev@gmail.com'
      );
    }

    function userDocExists() {
      return isSignedIn()
        && currentUserEmail() != null
        && exists(/databases/$(database)/documents/users/$(currentUserEmail()));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(currentUserEmail()));
    }

    function isAdmin() {
      return isSuperAdmin()
        || (userDocExists() && userDoc().data.role == 'admin');
    }

    function isSelf(userEmail) {
      return isSignedIn()
        && currentUserEmail() != null
        && currentUserEmail() == userEmail;
    }

    function isOwner(resourceData) {
      return isSignedIn() && resourceData.ownerUid == request.auth.uid;
    }

    match /users/{userEmail} {
      allow read: if isAdmin() || isSelf(userEmail);
      allow create: if isAdmin()
        || (isSelf(userEmail) && request.resource.data.role == 'viewer');
      allow update: if isAdmin()
        || (isSelf(userEmail) && request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /catalogs/{catalogId} {
      allow read: if resource.data.isPublic == true || isOwner(resource.data);
      allow create: if isSignedIn() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isOwner(resource.data);

      match /items/{itemId} {
        allow read: if get(/databases/$(database)/documents/catalogs/$(catalogId)).data.isPublic == true
          || isOwner(get(/databases/$(database)/documents/catalogs/$(catalogId)).data);
        allow write: if isOwner(get(/databases/$(database)/documents/catalogs/$(catalogId)).data);
      }
    }
  }
}
