rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserEmail() {
      return request.auth.token.email;
    }

    function isSuperAdmin() {
      return isSignedIn() && (
        currentUserEmail() == 'ti.vitoriana@gmail.com' || 
        currentUserEmail() == 'celiofs.dev@gmail.com' ||
        currentUserEmail() == 'celio@gmail.com'
      );
    }

    function userDocExists() {
      return isSignedIn()
        && currentUserEmail() != null
        && exists(/databases/$(database)/documents/users/$(currentUserEmail()));
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(currentUserEmail()));
    }

    function isAdmin() {
      return isSuperAdmin();
    }

    function isSelf(userEmail) {
      return isSignedIn()
        && currentUserEmail() != null
        && currentUserEmail() == userEmail;
    }

    function isOwner(resourceData) {
      return isSignedIn() && resourceData.ownerUid == request.auth.uid;
    }

    match /users/{userEmail} {
      allow read: if isSignedIn() && (isAdmin() || isSelf(userEmail));
      allow create: if isSignedIn() && (isAdmin() || isSelf(userEmail));
      allow update: if isSignedIn() && (isAdmin() || isSelf(userEmail));
      allow delete: if isAdmin();
    }

    match /tenants/{tenantId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // SaaS Level: Podem escrever se estiverem logados (filtragem feita no app por tenantId)
    }

    match /categories/{categoryId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /catalogs/{catalogId} {
      allow read: if (isSignedIn() && (resource.data.isPublic == true || isSuperAdmin())) || true; // Permitir leitura pública
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn();

      match /items/{itemId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }
  }
}
